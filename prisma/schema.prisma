generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())
  pageVisits PageVisit[]
}

model PageVisit {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  page      String
  duration  Int      // seconds
  createdAt DateTime @default(now())
}
